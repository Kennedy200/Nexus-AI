# ════════════════════════════════════════════════════════════
# Nexus AI — Backend Environment Configuration (Local AI)
# ════════════════════════════════════════════════════════════

# ── Security ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ── CORS Origins (comma-separated) ──────────────────────────
CORS_ORIGINS=http://localhost:8000,http://localhost:8001,http://127.0.0.1:8000

# ── Server Config ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nexus_ai.db

# ── Vector DB ─────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Embeddings ────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── AI Model ────────────────────────────────────────────────
# Threshold for anomaly detection (0.0 - 1.0)
ANOMALY_THRESHOLD=0.75
